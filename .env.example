# PostgreSQL
POSTGRES_USER=sd
POSTGRES_PASSWORD=sd
POSTGRES_DB=sd

# Внешний порт nginx
HTTP_PORT=8080

# JWT — обязательно сменить в продуктиве
JWT_SECRET=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Первый администратор (создаётся сидом, если пользователей нет)
SEED_ADMIN_EMAIL=admin@o-horizons.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# Вложения
DEFAULT_TICKET_ATTACHMENT_LIMIT_MB=25

# SLA-движок (Этап 3)
SLA_WARNING_THRESHOLD=0.75
WORKER_INTERVAL_SECONDS=60
